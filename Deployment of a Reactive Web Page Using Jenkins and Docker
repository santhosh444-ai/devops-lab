✅ Step 9 — Add pipeline script
Scroll to Pipeline section
Set:
Definition = Pipeline script
Paste this:
pipeline {    agent any    stages {        stage('Generate Reactive Site') {            steps {                script {                    sh 'rm -rf site || true'                    sh 'mkdir -p site/assets'                    writeFile file: 'site/index.html', text: """<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Karunya University — Reactive Site</title><link rel="stylesheet" href="assets/style.css"/></head><body><header class="site-header"><div class="container"><h1>Karunya University</h1><p class="tagline">Values — Knowledge — Service</p></div></header><main class="container"><section class="card"><h2 id="about-title"></h2><p id="about-text"></p><button onclick="updateContent()">Update Content</button></section></main><footer class="site-footer container"><p>&copy; ${new Date().format('yyyy')} Karunya University — Generated by Jenkins</p></footer><script src="assets/app.js"></script></body></html>"""                    writeFile file: 'site/assets/style.css', text: """body { font-family: Arial, sans-serif; margin:0; }.container { max-width:800px; margin:0 auto; padding:20px; }.site-header { background:#0b3d91; color:#fff; padding:20px; }.card { background:#fff; border:1px solid #ddd; padding:15px; border-radius:6px; }.site-footer { text-align:center; font-size:12px; color:#555; margin-top:20px; }button { padding:8px 12px; cursor:pointer; }"""                    writeFile file: 'site/assets/app.js', text: """let state = {  title: "About Karunya University",  description: "Karunya Institute of Technology and Sciences is a leading centre for higher education in India."};function render() {  document.getElementById("about-title").innerText = state.title;  document.getElementById("about-text").innerText = state.description;}function updateContent() {  state.description = "This content was updated dynamically without page reload!";  render();}document.addEventListener("DOMContentLoaded", render);"""                }            }        }        stage('Publish Site') {            steps {                publishHTML([                    allowMissing: false,                    alwaysLinkToLastBuild: true,                    keepAll: true,                    reportDir: 'site',                    reportFiles: 'index.html',                    reportName: 'Karunya University - Reactive Site'                ])            }        }    }    post {        always {            archiveArtifacts artifacts: 'site/**', fingerprint: true        }    }}
